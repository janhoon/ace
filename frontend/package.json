{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit",
    "lint": "biome lint src vite.config.ts",
    "lint:fix": "biome lint --write src vite.config.ts",
    "format": "biome format --write src vite.config.ts",
    "format:check": "biome format src vite.config.ts",
    "lint:dead-code": "knip"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
