    "marked": "^17.0.5",
    "monaco-editor": "^0.55.1",
    "posthog-js": "^1.363.1",
    "shiki": "^4.0.2",
    "vue": "^3.5.28",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.3",
    "vue3-grid-layout-next": "^1.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
