{
  "schema_version": 1,
  "dashboard": {
    "title": "VictoriaMetrics Cluster Health",
    "description": "Overview of VictoriaMetrics cluster performance, ingestion rate, query latency, and storage usage.",
    "panels": [
      {
        "title": "Active Time Series",
        "type": "stat",
        "grid_pos": { "x": 0, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "vm_cache_entries{type=\"storage/metricName\"}" }
      },
      {
        "title": "Ingestion Rate",
        "type": "stat",
        "grid_pos": { "x": 3, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "sum(rate(vm_rows_inserted_total[5m]))" }
      },
      {
        "title": "Query Rate",
        "type": "stat",
        "grid_pos": { "x": 6, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "sum(rate(vm_http_requests_total[5m]))" }
      },
      {
        "title": "Storage Used",
        "type": "stat",
        "grid_pos": { "x": 9, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "sum(vm_data_size_bytes) / 1024 / 1024 / 1024" }
      },
      {
        "title": "Ingestion Rate Over Time",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 4, "w": 6, "h": 8 },
        "query": { "expr": "sum(rate(vm_rows_inserted_total[5m]))", "legend_format": "rows/sec" }
      },
      {
        "title": "Query Latency (p99)",
        "type": "line_chart",
        "grid_pos": { "x": 6, "y": 4, "w": 6, "h": 8 },
        "query": { "expr": "histogram_quantile(0.99, sum(rate(vm_request_duration_seconds_bucket[5m])) by (le))", "legend_format": "p99" }
      },
      {
        "title": "Memory Usage",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 12, "w": 6, "h": 8 },
        "query": { "expr": "process_resident_memory_bytes / 1024 / 1024", "legend_format": "RSS (MB)" }
      },
      {
        "title": "Disk Usage Growth",
        "type": "line_chart",
        "grid_pos": { "x": 6, "y": 12, "w": 6, "h": 8 },
        "query": { "expr": "sum(vm_data_size_bytes) / 1024 / 1024 / 1024", "legend_format": "Storage (GB)" }
      }
    ],
    "variables": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "query": "label_values(vm_app_version, instance)",
        "multi": false,
        "include_all": true
      }
    ],
    "time_range": { "from": "now-1h", "to": "now" },
    "refresh_interval": "30s"
  }
}
