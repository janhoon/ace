{
  "schema_version": 1,
  "dashboard": {
    "title": "Node Exporter",
    "description": "System metrics from node_exporter: CPU, memory, disk, and network.",
    "panels": [
      {
        "title": "CPU Usage",
        "type": "gauge",
        "grid_pos": { "x": 0, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[5m])) * 100)" }
      },
      {
        "title": "Memory Usage",
        "type": "gauge",
        "grid_pos": { "x": 3, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})" }
      },
      {
        "title": "Disk Usage",
        "type": "gauge",
        "grid_pos": { "x": 6, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",instance=~\"$instance\"} / node_filesystem_size_bytes{mountpoint=\"/\",instance=~\"$instance\"} * 100)" }
      },
      {
        "title": "System Load (1m)",
        "type": "stat",
        "grid_pos": { "x": 9, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "node_load1{instance=~\"$instance\"}" }
      },
      {
        "title": "CPU Usage Over Time",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "query": { "expr": "100 - (avg by (cpu)(rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[5m])) * 100)", "legend_format": "CPU {{cpu}}" }
      },
      {
        "title": "Memory",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 12, "w": 6, "h": 8 },
        "query": { "expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}", "legend_format": "Used" }
      },
      {
        "title": "Network I/O",
        "type": "line_chart",
        "grid_pos": { "x": 6, "y": 12, "w": 6, "h": 8 },
        "query": { "expr": "rate(node_network_receive_bytes_total{device!=\"lo\",instance=~\"$instance\"}[5m])", "legend_format": "{{device}} rx" }
      },
      {
        "title": "Disk I/O",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 20, "w": 12, "h": 8 },
        "query": { "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\"}[5m])", "legend_format": "{{device}} read" }
      }
    ],
    "variables": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "query": "label_values(node_uname_info, instance)",
        "multi": false,
        "include_all": true
      }
    ],
    "time_range": { "from": "now-1h", "to": "now" },
    "refresh_interval": "30s"
  }
}
