{
  "schema_version": 1,
  "dashboard": {
    "title": "Go Runtime",
    "description": "Go application runtime metrics: goroutines, memory, GC, and HTTP performance.",
    "panels": [
      {
        "title": "Goroutines",
        "type": "stat",
        "grid_pos": { "x": 0, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "go_goroutines{instance=~\"$instance\"}" }
      },
      {
        "title": "Heap Alloc",
        "type": "stat",
        "grid_pos": { "x": 3, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "go_memstats_heap_alloc_bytes{instance=~\"$instance\"} / 1024 / 1024" }
      },
      {
        "title": "GC Pause (p99)",
        "type": "stat",
        "grid_pos": { "x": 6, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "go_gc_duration_seconds{quantile=\"0.99\",instance=~\"$instance\"} * 1000" }
      },
      {
        "title": "Threads",
        "type": "stat",
        "grid_pos": { "x": 9, "y": 0, "w": 3, "h": 4 },
        "query": { "expr": "go_threads{instance=~\"$instance\"}" }
      },
      {
        "title": "Goroutines Over Time",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 4, "w": 6, "h": 8 },
        "query": { "expr": "go_goroutines{instance=~\"$instance\"}", "legend_format": "goroutines" }
      },
      {
        "title": "Memory Usage",
        "type": "line_chart",
        "grid_pos": { "x": 6, "y": 4, "w": 6, "h": 8 },
        "query": { "expr": "go_memstats_heap_alloc_bytes{instance=~\"$instance\"} / 1024 / 1024", "legend_format": "heap (MB)" }
      },
      {
        "title": "GC Rate",
        "type": "line_chart",
        "grid_pos": { "x": 0, "y": 12, "w": 6, "h": 8 },
        "query": { "expr": "rate(go_gc_duration_seconds_count{instance=~\"$instance\"}[5m])", "legend_format": "GC/sec" }
      },
      {
        "title": "HTTP Request Rate",
        "type": "line_chart",
        "grid_pos": { "x": 6, "y": 12, "w": 6, "h": 8 },
        "query": { "expr": "sum(rate(http_requests_total{instance=~\"$instance\"}[5m])) by (handler)", "legend_format": "{{handler}}" }
      }
    ],
    "variables": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "query": "label_values(go_info, instance)",
        "multi": false,
        "include_all": true
      }
    ],
    "time_range": { "from": "now-1h", "to": "now" },
    "refresh_interval": "30s"
  }
}
